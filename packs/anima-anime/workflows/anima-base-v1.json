{
  "1": {
    "inputs": { "unet_name": "{{unet}}", "weight_dtype": "default" },
    "class_type": "UNETLoader",
    "_meta": { "title": "Load Anima Base v1.0" }
  },
  "3": {
    "inputs": { "clip_name": "{{clip}}", "type": "stable_diffusion", "device": "default" },
    "class_type": "CLIPLoader",
    "_meta": { "title": "Load Anima Qwen Text Encoder" }
  },
  "simpligen_lora_1": {
    "inputs": {
      "PowerLoraLoaderHeaderWidget": { "type": "PowerLoraLoaderHeaderWidget" },
      "➕ Add Lora": "",
      "model": ["1", 0],
      "clip": ["3", 0]
    },
    "class_type": "Power Lora Loader (rgthree)",
    "_meta": { "title": "SimpliGen User LoRAs" }
  },
  "2": {
    "inputs": { "model": ["simpligen_lora_1", 0], "shift": 3 },
    "class_type": "ModelSamplingAuraFlow",
    "_meta": { "title": "Anima Model Sampling (shift 3)" }
  },
  "4": {
    "inputs": {
      "text": "You are an assistant designed to generate anime images based on textual prompts. <Prompt Start>\nmasterpiece, best quality, score_7, safe, {{prompt}}",
      "clip": ["simpligen_lora_1", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Positive Prompt" }
  },
  "5": {
    "inputs": { "text": "{{negative_prompt}}", "clip": ["simpligen_lora_1", 1] },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Negative Prompt" }
  },
  "6": {
    "inputs": { "width": "{{width}}", "height": "{{height}}", "batch_size": 1 },
    "class_type": "EmptyLatentImage",
    "_meta": { "title": "Empty Latent Image" }
  },
  "7": {
    "inputs": {
      "seed": "{{seed}}",
      "steps": "{{steps}}",
      "cfg": "{{cfg}}",
      "sampler_name": "er_sde",
      "scheduler": "simple",
      "denoise": "{{denoise}}",
      "model": ["2", 0],
      "positive": ["4", 0],
      "negative": ["5", 0],
      "latent_image": ["6", 0]
    },
    "class_type": "KSampler",
    "_meta": { "title": "Anima Base Sampler (ER-SDE)" }
  },
  "8": {
    "inputs": { "vae_name": "{{vae}}" },
    "class_type": "VAELoader",
    "_meta": { "title": "Load Qwen Image VAE" }
  },
  "9": {
    "inputs": { "samples": ["7", 0], "vae": ["8", 0] },
    "class_type": "VAEDecode",
    "_meta": { "title": "Decode Image" }
  },
  "10": {
    "inputs": { "filename_prefix": "anima-base-v1", "images": ["9", 0] },
    "class_type": "SaveImage",
    "_meta": { "title": "Save Image" }
  }
}
