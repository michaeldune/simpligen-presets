    "_meta": { "title": "Load kl-f8-anime2 VAE" }
  },
  "5": {
    "inputs": { "width": "{{width}}", "height": "{{height}}", "batch_size": 1 },
    "class_type": "EmptyLatentImage",
    "_meta": { "title": "Empty Latent Image" }
  },
  "6": {
    "inputs": { "text": "masterpiece, best quality, highly detailed, {{prompt}}", "clip": ["10", 0] },
