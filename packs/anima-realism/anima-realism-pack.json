        "workflow": "workflows/photanima-v23-turbo.json",
        "unet": "photanima_v23Turbo.safetensors",
        "unetUrl": "https://civitai.com/api/download/models/3112450",
        "clip": "qwen_3_06b_base.safetensors",
        "vae": "qwen_image_vae.safetensors",
        "steps": 12,
        "cfg": 1,
        "denoise": 1,
        "negativePrompt": "",
        "resolutionOverrides": {
          "1:1": {
            "width": 1024,
