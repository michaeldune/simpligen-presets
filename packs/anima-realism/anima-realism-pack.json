          }
        },
        "requirements": {
          "minVramGB": 8,
          "recommendedVramGB": 12,
          "minRamGB": 16,
          "sizeGB": 5,
          "notes": "Anima (Cosmos) UNet + Qwen 0.6B encoder + Qwen-Image VAE. ER-SDE/simple, ModelSamplingAuraFlow shift 3. v2.3 Turbo distilled (low steps, CFG 1)."
        },
        "vaeUrl": "https://huggingface.co/Comfy-Org/Qwen-Image_ComfyUI/resolve/main/split_files/vae/qwen_image_vae.safetensors",
